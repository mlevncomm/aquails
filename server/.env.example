# Server environment
NODE_ENV=development
PORT=4000

# Comma-separated allowed origins (frontend + production domain)
CORS_ORIGINS=http://localhost:3000

# Database (required in FAZ 2 — placeholder only)
DATABASE_URL=postgresql://user:password@localhost:5432/aquails

# JWT (required in FAZ 3 — use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d
