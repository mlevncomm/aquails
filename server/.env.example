# Server environment
NODE_ENV=development
PORT=4000

# Comma-separated allowed origins (frontend + production domain)
# Local: http://localhost:3000
# Vercel: https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000

# PostgreSQL — Supabase (recommended) or local
#
# Supabase: Project Settings → Database → Connection string (URI)
#   DATABASE_URL = Transaction pooler (port 6543) + ?pgbouncer=true
#   DIRECT_URL   = Session/Direct (port 5432) — migrations & seed only
#
# Local: use the same URL for both variables
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aquails?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/aquails?schema=public
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# JWT (required for auth endpoints; min 32 chars in production)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Admin seed (development/staging only — never commit real passwords)
SEED_ADMIN_EMAIL=admin@aquails.com
SEED_ADMIN_NAME=Aquails Admin
SEED_ADMIN_PASSWORD=change-me-in-local-env-only

# Database commands (development):
#   npm run db:migrate:deploy
#   npm run db:seed
#
# Production deploy: npm run db:migrate:deploy
# Never use db push or db:reset in production (see server/DATABASE.md)
