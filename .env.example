# Frontend public env — safe for Vercel and local .env
VITE_APP_URL=http://localhost:3000
VITE_DATA_PROVIDER=supabase
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key

# Legacy Express parallel mode only (do not set on Vercel when using Supabase)
# VITE_API_URL=http://localhost:4000

# Edge Function secrets: set via `supabase secrets set` (never in Vercel or frontend)
# APP_URL=https://your-production-domain.com
