# Supabase (public — safe for frontend / Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public site URL (used by PayTR redirects / password recovery links in production)
SITE_URL=http://localhost:3000

# Postgres pooler (server-side / migrations — never commit real passwords)
# Transaction mode (app queries via pooler)
DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session mode (migrations / supabase db push)
DIRECT_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Server-only (Vercel Functions / scripts / CI — NEVER prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin bootstrap: npm run admin:create
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Test users / e2e scripts
TEST_EMAIL=test@example.com
TEST_PASSWORD=change-me
# Mutasyon yapan e2e testlerini yalnızca izole test projesinde açın
E2E_ALLOW_MUTATION=false

# PayTR (Vercel Function env / Supabase secrets — never expose to frontend)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=1

# Transactional e-mail outbox (server-only)
# RESEND_API_KEY=
# EMAIL_FROM=Aquails <noreply@example.com>
# CRON_SECRET=  # Must match Supabase Vault secret `aquails_cron_secret`
#
# Email outbox is triggered by Supabase pg_cron (every 10 minutes), not Vercel Cron.
# Create Vault secrets in the Supabase SQL editor (do not put real values in git):
#   select vault.create_secret('https://www.example.com', 'aquails_site_url');
#   select vault.create_secret('same-value-as-CRON_SECRET', 'aquails_cron_secret');
